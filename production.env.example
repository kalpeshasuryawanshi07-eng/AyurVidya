# AyurVidya Production Environment Template
# Use this as a reference for your server-side environment variables

# Node Environment
NODE_ENV=production
PORT=5000

# Security (CRITICAL: Change these for production)
JWT_SECRET=your_secure_random_production_jwt_secret_here

# Database
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/ayurvidya?retryWrites=true&w=majority

# CORS Configuration
# Set this to your frontend URL
CORS_ORIGIN=https://your-domain.vercel.app

# Razorpay Integration (Live Keys)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
